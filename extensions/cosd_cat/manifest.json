{
    "name": "cosd_cat",
    "description": "Display a message on the webpage",
    "version": "0.1",
    "manifest_version": 3,
    "content_scripts": [
        {
            "js": ["scripts/content.js"],
            "matches": ["*://*/*"],
            "run_at": "document_start"
        }
    ],
    "permissions": ["storage", "webRequest"],
    "host_permissions": ["*://*/*"],
    "background": {
        "service_worker": "scripts/service-worker.js"
    }
}
